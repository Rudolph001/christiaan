# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_trading_assistant
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=ai_trading_assistant

# Application Settings
NODE_ENV=development
PORT=5000

# Security (generate secure random strings)
SESSION_SECRET=your_secure_session_secret_change_this_in_production

# Discord Integration (optional)
# DISCORD_WEBHOOK_URL=your_discord_webhook_url

# AI Configuration
AI_CONFIDENCE_THRESHOLD=70
MAX_TRADES_PER_DAY=10
DEFAULT_RISK_PERCENTAGE=1.0

# Trading Configuration
STARTING_BALANCE=50000
TRADING_FEE_PERCENTAGE=0.075
WEEKEND_TRADING_ENABLED=true
AUTO_EXECUTE_AI=false

# Market Data (for future real integration)
# MARKET_DATA_API_KEY=your_market_data_api_key
# MARKET_DATA_PROVIDER=alpha_vantage

# Notifications
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password